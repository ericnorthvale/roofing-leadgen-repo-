{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    ".astro/content.d.ts",
    ".astro/env.d.ts",
    "**/*",
    "src/env.d.ts"
  ],
  "exclude": ["dist", "node_modules", ".vercel"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@content/*": ["src/content/*"],
      "@styles/*": ["src/styles/*"]
    },
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "jsx": "preserve"
  }
}
