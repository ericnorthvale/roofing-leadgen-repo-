# ─── Northvale Roofing — env variables ───────────────────────────────────
# Copy this to `.env` for local dev. In prod, set these in Vercel Project Settings.
# Names mirror astro.config.mjs `env.schema`. Do not commit real values.

# Public (safe to ship to the browser)
PUBLIC_SITE_URL="https://northvaleroofing.com"
PUBLIC_BRAND_NAME="Northvale Roofing"
PUBLIC_GA4_ID=""                         # e.g. G-XXXXXXXXXX — from Task 10
PUBLIC_GTM_ID=""                         # e.g. GTM-XXXXXXX  — server-side container
PUBLIC_CALLRAIL_COMPANY_ID=""            # CallRail JS snippet id for DNI on the browser
META_PIXEL_ID=""                         # Meta pixel id for client-side pageview (CAPI is server-side, below)
GOOGLE_ADS_CONVERSION_ID=""              # AW-XXXXXXXXX

# Server secrets (set only in Vercel env, never commit)
ANTHROPIC_API_KEY=""                     # reuse your existing key from bleck-deal-engine
OPENAI_API_KEY=""                        # reuse from bart-app
HIGHLEVEL_API_KEY=""                     # from HighLevel → Settings → Private Integrations
HIGHLEVEL_LOCATION_ID=""                 # HighLevel sub-account (location) id
CALLRAIL_API_KEY=""                      # from CallRail → Integrations → API v3
CALLRAIL_ACCOUNT_ID=""
CALLRAIL_WEBHOOK_SECRET=""               # shared secret for /api/callrail-webhook signature verification (generate one in CallRail → Webhooks)
GOOGLE_MAPS_API_KEY=""                   # reuse from bleck-deal-engine if scoped; else new key
GOOGLE_PLACES_API_KEY=""                 # for /reviews pull from GBP
GOOGLE_PLACE_ID=""                       # Northvale Roofing GBP Place ID (find at https://developers.google.com/maps/documentation/places/web-service/place-id)
META_CAPI_TOKEN=""                       # Meta Conversions API access token (server-side pixel)

# Optional — enable only when wired
VERCEL_ENV=""                            # auto-set by Vercel (production/preview/development)
