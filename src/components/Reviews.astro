---
import { getCollection } from "astro:content";

const all = await getCollection("reviews");
const published = all.slice(0, 3);
---

<section class="bg-[color:var(--color-navy-50)]">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-3xl">What our Woodlands + Spring neighbors say</h2>
    {
      published.length === 0 ? (
        <p class="mt-4 text-[color:var(--color-ink-800)]">
          Reviews will surface here once the Google Business Profile pull is wired (see
          TASKS_FOR_ERIC.md).
        </p>
      ) : (
        <div class="mt-8 grid gap-6 md:grid-cols-3">
          {published.map((r) => (
            <article class="rounded-[var(--radius-card)] bg-white p-6 shadow-[var(--shadow-card)]">
              <p class="text-sm">{r.data.text}</p>
              <p class="mt-4 text-sm font-semibold">{r.data.author}</p>
              <p class="text-xs text-[color:var(--color-ink-500)]">
                {r.data.source} · {r.data.relativeTime}
              </p>
            </article>
          ))}
        </div>
      )
    }
  </div>
</section>
