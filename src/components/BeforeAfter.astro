---
/**
 * Paired before/after band — the single most persuasive roofing visual. Renders
 * two ImagePlaceholder slots today; pass `beforeSrc` / `afterSrc` once real
 * matched photos exist (same project, same angle). No layout shift on swap.
 */
import ImagePlaceholder from "@components/ImagePlaceholder.astro";

interface Props {
  heading?: string;
  intro?: string;
  beforeLabel?: string;
  afterLabel?: string;
  beforeAlt?: string;
  afterAlt?: string;
  beforeSrc?: string;
  afterSrc?: string;
  class?: string;
}
const {
  heading = "Before & after",
  intro,
  beforeLabel = "BEFORE: storm-damaged roof",
  afterLabel = "AFTER: completed GAF roof",
  beforeAlt = "Roof before Northvale Roofing replacement, showing storm damage",
  afterAlt = "Completed GAF roof after Northvale Roofing replacement",
  beforeSrc,
  afterSrc,
  class: className,
} = Astro.props;
---

<section class:list={["mx-auto max-w-6xl px-4 py-16", className]}>
  <h2 class="text-3xl">{heading}</h2>
  {intro && <p class="mt-3 max-w-2xl text-[color:var(--color-ink-800)]">{intro}</p>}
  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <figure>
      <ImagePlaceholder
        slot={beforeLabel}
        alt={beforeAlt}
        src={beforeSrc}
        demoKey="before"
        ratio="4/3"
        tone="navy"
      />
      <figcaption class="mt-2 text-sm font-semibold text-[color:var(--color-ink-500)]">
        Before
      </figcaption>
    </figure>
    <figure>
      <ImagePlaceholder
        slot={afterLabel}
        alt={afterAlt}
        src={afterSrc}
        demoKey="after"
        ratio="4/3"
        tone="gold"
      />
      <figcaption class="mt-2 text-sm font-semibold text-[color:var(--color-ink-500)]">
        After
      </figcaption>
    </figure>
  </div>
</section>
