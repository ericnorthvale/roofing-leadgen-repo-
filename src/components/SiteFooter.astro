---
import { BRAND } from "~/lib/brand";
import { LEGAL } from "~/lib/legal";
import { SERVICE_AREAS } from "~/lib/service-areas";
import { telHref, formatPhoneDisplay } from "~/lib/phone";

const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[color:var(--color-navy-100)] bg-[color:var(--color-navy-950)] text-[color:var(--color-navy-100)]"
>
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 py-14 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-3">
        <img src="/brand/logo.svg" alt="" width="36" height="36" />
        <span class="font-serif text-lg text-white">{BRAND.name}</span>
      </div>
      <p class="mt-3 text-sm">{BRAND.tagline}</p>
      <p class="mt-3 text-sm">
        <a href={telHref(BRAND.phoneE164)} class="text-white underline"
          >{formatPhoneDisplay(BRAND.phoneE164)}</a
        >
      </p>
      <p class="text-sm">{BRAND.hoursSummary}</p>
    </div>

    <div>
      <h4 class="text-sm font-semibold tracking-wider text-white uppercase">Services</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/services/roof-replacement">Roof replacement</a></li>
        <li><a href="/services/roof-repair">Roof repair</a></li>
        <li><a href="/services/roof-inspection">Roof inspection</a></li>
        <li><a href="/services/storm-damage">Storm damage</a></li>
        <li><a href="/services/insurance-claims">Insurance claims</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold tracking-wider text-white uppercase">Service areas</h4>
      <ul class="mt-3 space-y-2 text-sm">
        {
          Object.values(SERVICE_AREAS).map((a) => (
            <li>
              <a href={`/${a.slug}`}>{a.name}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold tracking-wider text-white uppercase">Company</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/about">About</a></li>
        <li><a href="/reviews">Reviews</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/for-agents">For agents</a></li>
        <li><a href="/for-insurance-partners">For insurance partners</a></li>
        <li><a href="/for-hoa">For HOAs</a></li>
        <li><a href="/for-inspectors">For inspectors</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-6 text-xs text-[color:var(--color-navy-100)] md:flex-row md:items-center md:justify-between"
    >
      <p>© {year} {BRAND.legalName}. All rights reserved.</p>
      <nav class="flex flex-wrap gap-4" aria-label="Legal">
        <a href="/legal/privacy">Privacy</a>
        <a href="/legal/terms">Terms</a>
        <a href="/legal/tcpa">TCPA notice</a>
        <a href="/legal/accessibility">Accessibility</a>
        <a href="/sitemap">Sitemap</a>
      </nav>
    </div>
    <div class="mx-auto max-w-6xl px-4 pb-10 text-xs text-[color:var(--color-navy-100)]/80">
      <p>{LEGAL.licenseLine}</p>
    </div>
  </div>
</footer>
