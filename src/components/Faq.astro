---
/**
 * Visible, accessible FAQ. The answer text lives in the DOM so it's crawlable.
 * Emit the matching FAQPage JSON-LD separately via faqPageJsonLd() in the page's
 * `seo.jsonLd` — only when the Q&A is real and present on the page.
 */
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items: FaqItem[];
  heading?: string;
}
const { items, heading = "Common questions" } = Astro.props;
---

{
  items.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-2xl md:text-3xl">{heading}</h2>
      <dl class="mt-6 divide-y divide-[color:var(--color-navy-100)]">
        {items.map((item) => (
          <div class="py-5">
            <dt class="font-serif text-lg text-[color:var(--color-navy-900)]">{item.q}</dt>
            <dd class="mt-2 text-[color:var(--color-ink-800)]">{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>
  )
}
