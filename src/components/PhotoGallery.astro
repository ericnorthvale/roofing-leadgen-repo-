---
/**
 * Responsive photo gallery — renders real job photos (e.g. from CompanyCam) via
 * the RoofImage wrapper so alt text is always present. Renders nothing when there
 * are no photos, so it's safe to drop on a page before CompanyCam is connected.
 */
import RoofImage from "@components/RoofImage.astro";

interface GalleryPhoto {
  url: string;
  alt: string;
}
interface Props {
  photos: GalleryPhoto[];
  heading?: string;
}
const { photos, heading = "Recent work" } = Astro.props;
---

{
  photos.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-2xl md:text-3xl">{heading}</h2>
      <div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-4">
        {photos.map((p) => (
          <RoofImage
            src={p.url}
            alt={p.alt}
            class="aspect-square w-full rounded-[var(--radius-card)] object-cover"
          />
        ))}
      </div>
    </section>
  )
}
