---
import BaseLayout from "@layouts/BaseLayout.astro";
import ServiceCard from "@components/ServiceCard.astro";
import { SERVICE_LIST } from "~/lib/services";
---

<BaseLayout
  seo={{
    title: "Services",
    description:
      "Roof replacement, repair, inspection, storm damage, and insurance claim support. Every job signed off by a named project manager.",
    pathname: "/services",
  }}
>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-4xl md:text-5xl">Services</h1>
    <p class="mt-4 max-w-2xl text-lg">
      Every job, every service, signed off by a named project manager. Forty-photo documentation
      packet at close.
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        SERVICE_LIST.map((service) => (
          <ServiceCard
            href={`/services/${service.slug}`}
            title={service.title}
            badge={service.serviceTag === "inspection" ? "Free" : undefined}
            blurb={service.summary}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
