---
import BaseLayout from "@layouts/BaseLayout.astro";
import { renderDataLayerPush } from "~/lib/analytics";
import { BRAND } from "~/lib/brand";

const conversionScript = renderDataLayerPush({
  eventName: "lead_submitted",
  value: 75,
  currency: "USD",
});
---
<BaseLayout seo={{ title: "We've got it from here", description: "Thanks — you'll hear back in under 60 seconds.", pathname: "/thank-you", noindex: true }}>
  <section class="mx-auto max-w-2xl px-4 py-20 text-center">
    <h1 class="text-4xl md:text-5xl">We've got it from here.</h1>
    <p class="mt-4 text-lg">You'll hear back in under 60 seconds between 8am and 9pm CT, or first thing in the morning.</p>
    <p class="mt-4 text-sm text-[color:var(--color-ink-500)]">
      Prefer to text us directly? {BRAND.phoneDisplay}.
    </p>
  </section>
  <script is:inline set:html={conversionScript} />
</BaseLayout>
