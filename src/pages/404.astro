---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTAButton from "@components/CTAButton.astro";
---

<BaseLayout
  seo={{
    title: "Page not found",
    description: "That page isn't here.",
    pathname: "/404",
    noindex: true,
  }}
>
  <section class="mx-auto max-w-xl px-4 py-20 text-center">
    <h1 class="text-4xl">That page isn't here.</h1>
    <p class="mt-4 text-lg">Try the services index or just text us — we'll figure it out.</p>
    <div class="mt-8 flex justify-center gap-3">
      <CTAButton href="/services" label="See services" />
      <CTAButton href="/contact" variant="ghost" label="Contact us" />
    </div>
  </section>
</BaseLayout>
