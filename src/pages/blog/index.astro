---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const all = await getCollection("blog");
const posts = all
  .filter((p) => p.data.status === "published")
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout seo={{ title: "Roofing insights + storm notes", description: "Field-written articles on roof replacement, repair, insurance claims, and Texas storm season.", pathname: "/blog" }}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-4xl md:text-5xl">Field notes</h1>
    <p class="mt-3 text-lg text-[color:var(--color-ink-500)]">Short-form homeowner guides, long-form how-it-works, plus Texas storm season updates.</p>
    {posts.length === 0 ? (
      <p class="mt-8">The content pipeline will start publishing posts here after the first weekly run — see <code>.github/workflows/content-pipeline.yml</code>.</p>
    ) : (
      <ul class="mt-10 space-y-8">
        {posts.map((p) => (
          <li>
            <article>
              <h2 class="text-2xl"><a href={`/blog/${p.id}/`}>{p.data.title}</a></h2>
              <p class="mt-1 text-sm text-[color:var(--color-ink-500)]">
                <time datetime={p.data.pubDate.toISOString()}>{p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
                · {p.data.cluster}
              </p>
              <p class="mt-2">{p.data.description}</p>
            </article>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
