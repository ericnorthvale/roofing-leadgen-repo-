{
  "name": "northvale-roofing",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Website + lead-gen + content engine for Northvale Roofing (The Woodlands, TX).",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "start": "astro dev",
    "typecheck": "astro check",
    "lint": "prettier --check . && astro check",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lhci": "lhci autorun"
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.3",
    "@astrojs/react": "^4",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/vercel": "^8.0.2",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "vitest": "^2.1.8"
  }
}
